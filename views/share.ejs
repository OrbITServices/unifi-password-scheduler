<%- include('partials_header') %>
<div class="card" style="background:#fff;color:#111;max-width:760px;margin:0 auto">
  <p><button onclick="window.print()">Print</button></p>
  <h1><%= wifi.ssid_name %></h1>
  <p>Scan the QR code or use the password below.</p>
  <p><img src="<%= qr %>" alt="QR" style="max-width:280px"></p>
  <p><strong>Password:</strong> <code><%= wifi.last_password %></code></p>
  <p><strong>Updated:</strong> <%= wifi.last_changed_at || '' %></p>
</div>
<%- include('partials_footer') %>
